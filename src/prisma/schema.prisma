// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Payment {
  id Int @id @default(autoincrement())
  name String
  amount Decimal @db.Decimal(10,2)
  startDate DateTime
  endDate DateTime

  instances PaymentInstance[]

  dueDates PaymentDueDate[]

  userId Int
  user User @relation(fields: [userId], references: [id])
}

model PaymentInstance {
  id Int @id @default(autoincrement())
  name String?
  amount Decimal? @db.Decimal(10,2)
  preparedAmount Decimal @default(0) @db.Decimal(10,2)
  isPaid Boolean @default(false)
  dueDate DateTime

  paymentId Int
  payment Payment @relation(fields: [paymentId], references: [id])
}

model PaymentDueDate {
  id Int @id @default(autoincrement())
  
  paymentId Int
  payment Payment @relation(fields: [paymentId], references: [id])

  dueDateOnMonth Int 

  @@unique([paymentId, dueDateOnMonth])
}

model User {
  id Int @id @default(autoincrement())
  fullName String
  email String
  googleId String? @unique
  provider String @default("google")

  transactions Transaction[]

  payments Payment[]

  wishlists Wishlist[]

  funds Fund[]

  account Account?
}

model Transaction {
  id Int @id @default(autoincrement())
  name String @default("transaction")
  type TransactionType @default(EXPENSE)
  amount Decimal @db.Decimal(10,2) @default(0)
  note String?
  image String?
  transactionDate DateTime @default(now())

  userId Int
  user User @relation(fields: [userId], references: [id])
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Account {
  id Int @id @default(autoincrement())
  balance Decimal @default(0) @db.Decimal(10,2)
  safeToSpend Decimal @default(0) @db.Decimal(10,2)
  safeToSpendUntil DateTime @default(now())
  
  userId Int @unique
  user User @relation(fields: [userId], references: [id])
}

model Wishlist {
  id Int @id @default(autoincrement())
  name String @default("wishlist item")
  price Decimal @default(0) @db.Decimal(10,2)
  reserved Decimal @default(0) @db.Decimal(10,2)
  image String @default("#")
  description String @default("description for the wishlist item")
  
  userId Int
  user User @relation(fields: [userId], references: [id])
}

model Fund {
  id Int @id @default(autoincrement())
  name String @default("fund item")
  reserved Decimal @default(0) @db.Decimal(10,2)
  image String @default("#")
  description String @default("description for the fund item")
  
  userId Int
  user User @relation(fields: [userId], references: [id])
}